rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match any document within the budgetTool collection or any of its subcollections
    match /budgetTool/{allPaths=**} {
      // Allow public read access to everything under budgetTool
      allow read: if true;
    }

    // Fine-grained write access to only required collections
    match /budgetTool/default/shareCodes/{code} {
      allow write: if true;
    }

    match /budgetTool/{group}/budgets/{budgetId} {
      allow write: if true;
    }

    // Explicitly deny all other collections for security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}