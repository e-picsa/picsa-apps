{
  "root": true,
  "ignorePatterns": ["**/*"],
  "plugins": ["@nx", "simple-import-sort", "@angular-eslint"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "warn",
          {
            "enforceBuildableLibDependency": true,
            "allow": [
              "@picsa/components",
              "@picsa/forms",
              "@picsa/server-types",
              "@picsa/server-utils",
              "@picsa/shared"
            ],
            "depConstraints": [
              {
                "sourceTag": "*",
                "onlyDependOnLibsWithTags": ["*"]
              }
            ]
          }
        ],

        "no-restricted-imports": [
          "error",
          {
            "name": "@ngx-translate/core",
            "importNames": ["TranslateModule", "TranslatePipe"],
            "message": "Please use PicsaTranslateModule instead"
          }
        ],
        "@angular-eslint/component-selector": ["warn"],
        "@angular-eslint/component-class-suffix": ["warn"],
        "@angular-eslint/prefer-inject": ["warn"],
        "@angular-eslint/prefer-on-push-component-change-detection": "warn",
        "@angular-eslint/prefer-standalone": "warn",
        "@typescript-eslint/no-explicit-any": ["warn"],
        "@typescript-eslint/no-loss-of-precision": ["warn"],
        "@typescript-eslint/no-non-null-assertion": "warn",
        "@typescript-eslint/no-unused-vars": ["warn"],
        "no-loss-of-precision": "off",
        "no-prototype-builtins": "off",
        "no-unused-vars": "off",
        "simple-import-sort/imports": "warn",
        "simple-import-sort/exports": "warn"
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nx/typescript", "prettier"],
      "rules": {
        "@typescript-eslint/no-extra-semi": "error",
        "no-extra-semi": "off"
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nx/javascript"],
      "rules": {
        "@typescript-eslint/no-extra-semi": "error",
        "no-extra-semi": "off"
      }
    },
    {
      "files": ["*.html"],
      "parser": "@angular-eslint/template-parser",
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "TextAttribute[name='mat-button']",
            "message": "❌ Don't use legacy <button mat-button>. ✅ Use MDC <button matButton>"
          },
          {
            "selector": "TextAttribute[name='mat-flat-button']",
            "message": "❌ Don't use legacy <button mat-flat-button>. ✅ Use MDC <button matButton='filled'>"
          },
          {
            "selector": "TextAttribute[name='mat-icon-button']",
            "message": "❌ Don't use legacy <button mat-icon-button>. ✅ Use MDC <button matIconButton> or <button matButton='outlined' class='icon-only'>."
          },
          {
            "selector": "TextAttribute[name='mat-raised-button']",
            "message": "❌ Don't use legacy <button mat-raised-button>. ✅ Use MDC <button matButton='elevated'>"
          },
          {
            "selector": "TextAttribute[name='mat-stroked-button']",
            "message": "❌ Don't use legacy <button mat-stroked-button>. ✅ Use MDC <button matButton='outlined'>"
          },
          {
            "selector": "TextAttribute[name='mat-fab']",
            "message": "❌ Don't use legacy <button mat-fab>. ✅ Use MDC <button matFab>"
          },
          {
            "selector": "TextAttribute[name='mat-mini-fab']",
            "message": "❌ Don't use legacy <button mat-mini-fab>. ✅ Use MDC <button matMiniFab>"
          }
        ]
      }
    }
  ]
}
